{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-kit.local/schemas/github-collaboration.schema.json",
  "title": "GitHubCollaboration",
  "type": "object",
  "required": ["version", "owner", "commit_provenance", "pr_collaboration"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "owner": {
      "type": "object",
      "required": ["display_name", "github_user"],
      "additionalProperties": true,
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "github_user": { "type": "string", "minLength": 1 }
      }
    },
    "commit_provenance": {
      "type": "object",
      "required": ["ai_disclosure_mode"],
      "additionalProperties": true,
      "properties": {
        "ai_disclosure_mode": {
          "type": "string",
          "enum": ["none"],
          "default": "none"
        },
        "assisted_by": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tool"],
            "additionalProperties": true,
            "properties": {
              "tool": { "type": "string", "minLength": 1 },
              "model": { "type": ["string", "null"] },
              "agent": { "type": ["string", "null"] }
            }
          }
        },
        "human_coauthors": { "type": "array" },
        "forbid_in_commits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "co_author_trailer": { "type": "object" }
      }
    },
    "pr_collaboration": {
      "type": "object",
      "required": ["pipelines"],
      "additionalProperties": true,
      "properties": {
        "pipelines": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["agents"],
            "additionalProperties": true,
            "properties": {
              "agents": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "requires_alignment_artifacts": { "type": "boolean" },
              "session_pointer": { "type": "string" }
            }
          }
        },
        "collaborators": { "type": "object" },
        "pr_body": { "type": "object" }
      }
    }
  }
}
